{
  "name": "antd-number-input",
  "type": "module",
  "version": "1.1.6",
  "description": "A React number input component based on Ant Design, with precision control and validation",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npx tsc -p tsconfig.json && npx vite build",
    "dev": "npx vite build --watch",
    "preview": "npx vite --config vite.config.preview.ts",
    "build:preview": "npx vite build --config vite.config.preview.ts",
    "prepublishOnly": "npm run build",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"preview/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "antd": ">=6.0.0",
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "^6.0.1",
    "antd": "^6.3.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.12"
  },
  "keywords": [
    "react",
    "antd",
    "number-input",
    "input",
    "form",
    "typescript"
  ],
  "author": "Czw96",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Czw96/antd-number-input.git"
  },
  "bugs": {
    "url": "https://github.com/Czw96/antd-number-input/issues"
  },
  "homepage": "https://github.com/Czw96/antd-number-input#readme"
}
